{
	"name": "tracelattice",
	"version": "1.2.7",
	"description": "Semantic Sequential Thinking Tools For Agentic Tools",
	"type": "module",
	"main": "dist/lib.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"bin": {
		"tracelattice": "./dist/cli.js"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "rslib build && rsbuild build -c rsbuild.config.ts && node scripts/postbuild-cli.mjs",
		"build:lib": "rslib build",
		"build:cli": "rsbuild build -c rsbuild.config.ts && node scripts/postbuild-cli.mjs",
		"start": "bun dist/cli.js",
		"dev": "bunx @modelcontextprotocol/inspector dist/cli.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"format": "prettier --write \"src/**/*.ts\" \"*.{json,md}\"",
		"format:check": "prettier --check \"src/**/*.ts\" \"*.{json,md}\"",
		"type-check": "tsc --noEmit",
		"prepublishOnly": "npm run type-check && npm run lint && npm run test"
	},
	"keywords": [
		"mcp",
		"model-context-protocol",
		"sequential-thinking",
		"problem-solving",
		"tool-recommendation",
		"decision-making",
		"thought-process",
		"step-by-step",
		"llm",
		"ai",
		"branching-thoughts",
		"thought-revision",
		"tool-analysis",
		"problem-breakdown",
		"solution-planning",
		"adaptive-thinking",
		"reflective-analysis",
		"tool-confidence"
	],
	"author": "CCWorkforces Engineers",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/OCWorkforces/TraceLattice.git"
	},
	"bugs": {
		"url": "https://github.com/OCWorkforces/TraceLattice/issues"
	},
	"homepage": "https://github.com/OCWorkforces/TraceLattice#readme",
	"dependencies": {
		"@tmcp/adapter-valibot": "^0.1.5",
		"@tmcp/transport-stdio": "^0.4.2",
		"chalk": "^5.6.2",
		"chokidar": "^5.0.0",
		"tmcp": "^1.19.3",
		"valibot": "^1.3.1",
		"yaml": "^2.8.3"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"@eslint/js": "^10.0.1",
		"@rsbuild/core": "^1.7.5",
		"@rslib/core": "^0.21.0",
		"@tsconfig/node24": "^24.0.4",
		"@types/node": "^25.6.0",
		"@typescript-eslint/eslint-plugin": "^8.58.1",
		"@typescript-eslint/parser": "^8.58.1",
		"@vitest/coverage-v8": "^4.1.4",
		"eslint": "^10.2.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vitest": "^4.1.4"
	}
}
