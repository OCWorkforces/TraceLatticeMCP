# TraceLattice MCP Server - Environment Variables Example
# Copy this file to .env and configure as needed

# =============================================================================
# TRANSPORT CONFIGURATION
# =============================================================================
# Transport type: 'stdio', 'sse', or 'streamable-http'
# - stdio: Standard input/output (default, single-user)
# - sse: Server-Sent Events (multi-user, streaming, legacy)
# - streamable-http: MCP Streamable HTTP (multi-user, production)
TRANSPORT_TYPE=streamable-http

# =============================================================================
# STREAMABLE HTTP TRANSPORT (when TRANSPORT_TYPE=streamable-http)
# =============================================================================
# Port for Streamable HTTP server (default: 3000)
STREAMABLE_HTTP_PORT=3000

# Host for Streamable HTTP server (default: localhost)
STREAMABLE_HTTP_HOST=localhost

# Enable stateful session tracking via Mcp-Session-Id header (default: true)
# When false, each request is processed independently (stateless)
STREAMABLE_HTTP_STATEFUL=true

# =============================================================================
# SSE TRANSPORT SETTINGS (when TRANSPORT_TYPE=sse)
# =============================================================================
# Port for SSE server (default: 3000)
# Also used as fallback for STREAMABLE_HTTP_PORT if not set
SSE_PORT=3000

# Host for SSE server (default: localhost)
# Also used as fallback for STREAMABLE_HTTP_HOST if not set
SSE_HOST=localhost

# Enable connection pool for session isolation (default: true)
SSE_ENABLE_POOL=true

# Maximum number of concurrent sessions (default: 100)
SSE_MAX_SESSIONS=100

# Session timeout in milliseconds (default: 300000 = 5 minutes)
SSE_SESSION_TIMEOUT=300000

# =============================================================================
# CORS SETTINGS
# =============================================================================
# CORS origin to allow (default: *)
# Use specific origin for production: https://yourdomain.com
CORS_ORIGIN=*

# Enable CORS preflight (default: true)
ENABLE_CORS=true

# Comma-separated list of allowed hosts (default: not set = all allowed)
# ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Maximum number of thoughts in history (default: 1000)
MAX_HISTORY_SIZE=1000

# Maximum number of branches (default: 50)
MAX_BRANCHES=50

# Maximum size of each branch (default: 100)
MAX_BRANCH_SIZE=100

# =============================================================================
# LOGGING
# =============================================================================
# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Enable pretty log output (default: true)
PRETTY_LOG=true

# =============================================================================
# SKILL DISCOVERY
# =============================================================================
# Colon-separated list of skill directories
SKILL_DIRS=.claude/skills:~/.claude/skills

# Discovery cache TTL in milliseconds (default: 300000 = 5 minutes)
DISCOVERY_CACHE_TTL=300000

# Discovery cache max entries (default: 100)
DISCOVERY_CACHE_MAX_SIZE=100

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# All feature flags default to false unless explicitly set.
# Boolean values: true/false/1/0 (case-insensitive)

# Enable DAG edges for thought relationships (default: false)
# TRACELATTICE_FEATURES_DAG_EDGES=false

# Enable confidence calibration with Beta(2,2) priors (default: false)
# TRACELATTICE_FEATURES_CALIBRATION=false

# Enable branch compression for cold branches (default: false)
# TRACELATTICE_FEATURES_COMPRESSION=false

# Enable tool interleave (suspend/resume for tool calls) (default: false)
# TRACELATTICE_FEATURES_TOOL_INTERLEAVE=false

# Enable new thought types: tool_call, tool_observation, assumption, decomposition, backtrack (default: false)
# TRACELATTICE_FEATURES_NEW_THOUGHT_TYPES=false

# Enable outcome recording for tool_call/tool_observation (default: false)
# TRACELATTICE_FEATURES_OUTCOME_RECORDING=false

# Reasoning strategy: sequential, tot, debate, or auto (default: sequential)
# TRACELATTICE_FEATURES_REASONING_STRATEGY=sequential

# =============================================================================
# TOOL INTERLEAVE TUNING (when TRACELATTICE_FEATURES_TOOL_INTERLEAVE=true)
# =============================================================================
# Suspension TTL in milliseconds — how long a suspended tool call remains valid (default: 300000 = 5 minutes)
# TRACELATTICE_TOOL_INTERLEAVE_TTL_MS=300000

# Sweep interval in milliseconds — how often expired suspensions are cleaned up (default: 60000 = 1 minute)
# TRACELATTICE_TOOL_INTERLEAVE_SWEEP_MS=60000

# =============================================================================
# DEBUGGING
# =============================================================================
# Enable verbose logging for file watchers (default: not set = quiet)
# WATCHER_VERBOSE=true
