# TraceLattice MCP Server - Environment Variables Example
# Copy this file to .env and configure as needed

# =============================================================================
# TRANSPORT CONFIGURATION
# =============================================================================
# Transport type: 'stdio', 'sse', or 'http'
# - stdio: Standard input/output (default, single-user)
# - sse: Server-Sent Events (multi-user, streaming)
# - http: HTTP request-response (REST-like API)
TRANSPORT_TYPE=http

# =============================================================================
# HTTP TRANSPORT SETTINGS
# =============================================================================
# Port for HTTP server (default: 9108)
HTTP_PORT=9108

# Host for HTTP server (default: 127.0.0.1)
HTTP_HOST=127.0.0.1

# Path for the messages endpoint (default: /mcp)
HTTP_PATH=/mcp

# =============================================================================
# SSE TRANSPORT SETTINGS (when TRANSPORT_TYPE=sse)
# =============================================================================
# Port for SSE server (default: 9108)
SSE_PORT=9108

# Host for SSE server (default: 127.0.0.1)
SSE_HOST=127.0.0.1

# =============================================================================
# CORS SETTINGS
# =============================================================================
# CORS origin to allow (default: *)
# Use specific origin for production: https://yourdomain.com
CORS_ORIGIN=*

# Enable CORS preflight (default: true)
ENABLE_CORS=true

# =============================================================================
# RATE LIMITING
# =============================================================================
# Enable rate limiting per IP (default: true)
ENABLE_RATE_LIMIT=true

# Maximum requests per minute per IP (default: 100)
MAX_REQUESTS_PER_MINUTE=100

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Maximum number of thoughts in history (default: 1000)
MAX_HISTORY_SIZE=1000

# Maximum number of branches (default: 50)
MAX_BRANCHES=50

# Maximum size of each branch (default: 100)
MAX_BRANCH_SIZE=100

# =============================================================================
# LOGGING
# =============================================================================
# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Enable pretty log output (default: true)
PRETTY_LOG=true

# =============================================================================
# SKILL DISCOVERY
# =============================================================================
# Colon-separated list of skill directories
SKILL_DIRS=.claude/skills:~/.claude/skills

# Discovery cache TTL in milliseconds (default: 300000 = 5 minutes)
DISCOVERY_CACHE_TTL=300000

# Discovery cache max entries (default: 100)
DISCOVERY_CACHE_MAX_SIZE=100

# =============================================================================
# PERSISTENCE
# =============================================================================
# Persistence backend: 'file', 'sqlite', or 'memory' (default: file)
PERSISTENCE_BACKEND=file

# Data directory for file-based persistence
PERSISTENCE_DATA_DIR=./data

# SQLite database path (when using sqlite backend)
PERSISTENCE_DB_PATH=./data/thoughts.db
